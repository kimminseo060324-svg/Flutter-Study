// 2.5 인터페이스
// GirlGroup이라는 클래스를 정의하고, Idol이라는 인터페이스를 구현한다고 명시
// implements 키워드를 사용하면 클래스가 인터페이스에 정의된 메서드를 반드시 구현해야 함
class GirlGroup implements Idol {
  // name이라는 이름 속성을 정의하고 final로 선언 → 한 번 값이 설정되면 변경 불가
  final String name;

  // membersCount라는 멤버 수 속성을 정의하고 final로 선언 → 변경 불가
  final int membersCount;

  // 생성자 정의
  // this.name과 this.membersCount를 사용해 외부에서 전달받은 값으로 객체 초기화
  GirlGroup(this.name, this.membersCount);

  // sayName 메서드 정의
  // 객체의 이름을 출력하는 기능
  void sayName() {
    // print 함수를 이용해 "저는 여자 아이돌 [name]입니다." 출력
    print('저는 여자 아이돌 ${this.name}입니다.');
  }

  // sayMembersCount 메서드 정의
  // 객체의 멤버 수를 출력하는 기능
  void sayMembersCount() {
    // print 함수를 이용해 "[name] 멤버는 [membersCount]명입니다." 출력
    print('${this.name} 멤버는 ${this.membersCount}명입니다.');
  }

  // main 메서드 정의 (클래스 내부에서 실행 테스트용)
  void main() {
    // GirlGroup 객체 black 생성, 이름 '블랙핑크', 멤버 4명
    GirlGroup black = GirlGroup('블랙핑크', 4);

    // sayName 메서드 호출 → 이름 출력
    black.sayName();

    // sayMembersCount 메서드 호출 → 멤버 수 출력
    black.sayMembersCount();
  }
}

// 2.6 믹스인
// Idol2라는 인터페이스(혹은 클래스)를 기반으로 믹스인을 정의
// mixin 키워드로 IdolSingMixin 생성, on Idol2 → Idol2를 상속받는 클래스에서만 사용 가능
mixin IdolSingMixin on Idol2 {

  // sing 메서드 정의
  // Idol2를 상속받은 클래스의 name 속성을 활용해 노래를 부르는 문구 출력
  void sing() {
    print('${this.name}이 노래를 부릅니다.');
  }
}

// BoyGroup 클래스 정의
// Idol2를 상속받고, IdolSingMixin 믹스인을 적용 → with 키워드 사용
class BoyGroup extends Idol2 with IdolSingMixin {

  // 생성자 정의
  // super.name, super.membersCount를 사용해 부모 클래스(Idol2) 속성 초기화
  BoyGroup(super.name, super.membersCount);

  // sayMale 메서드 정의
  // 남자 아이돌임을 출력
  void sayMale() {
    print("I AM 남자아이돌");
  }
}

// main 함수 정의
// 프로그램 실행 시작점
void main() {

  // BoyGroup 객체 bts 생성, 이름 'bts', 멤버 수 7
  BoyGroup bts = BoyGroup('bts', 7);

  // 믹스인 IdolSingMixin에 정의된 sing() 메서드 호출 가능
  bts.sing();
}

// 2.7 추상
// Idol3라는 추상 클래스 정의
// abstract 키워드를 사용하면 객체를 직접 생성할 수 없고, 상속 또는 구현을 통해서만 사용 가능
abstract class Idol3 {

  // name 속성 선언 (변경 불가능한 final)
  final String name;

  // membersCount 속성 선언 (멤버 수, final로 변경 불가)
  final int membersCount;

  // 생성자 정의
  // name과 membersCount 값을 외부에서 받아 초기화
  Idol3(this.name, this.membersCount);

  // sayName 추상 메서드 선언
  // 구현(내용)은 없고, 반드시 자식 클래스에서 오버라이딩해야 함
  void sayName();

  // sayMembersCount 추상 메서드 선언
  // 자식 클래스에서 반드시 구현해야 하는 메서드
  void sayMembersCount();
}

// GirlGroup 클래스 정의
// Idol3 추상 클래스를 implements로 구현
// → Idol3에 선언된 모든 메서드를 반드시 구현해야 함
class GirlGroup implements Idol3 {

  // Idol3에서 정의된 name 속성을 동일하게 선언
  final String name;

  // Idol3에서 정의된 membersCount 속성을 동일하게 선언
  final int membersCount;

  // 생성자 정의
  // 전달받은 name과 membersCount로 객체 초기화
  GirlGroup(this.name, this.membersCount);

  // sayName 메서드 구현 (추상 메서드 구현 필수)
  void sayName() {
    // "저는 여자 아이돌 [name]입니다." 출력
    print('저는 여자 아이돌 ${this.name}입니다.');
  }

  // sayMembersCount 메서드 구현 (추상 메서드 구현 필수)
  void sayMembersCount() {
    // "[name] 멤버는 [membersCount]명입니다." 출력
    print("${this.name} 멤버는 ${this.membersCount}명입니다.");
  }
}

// main 함수 정의 (프로그램 실행 시작점)
void main() {

  // GirlGroup 객체 생성 (이름: 블랙핑크, 멤버 수: 4)
  GirlGroup blackpink = GirlGroup('블랙핑크', 4);

  // sayName 메서드 호출 → 이름 출력
  blackpink.sayName();

  // sayMembersCount 메서드 호출 → 멤버 수 출력
  blackpink.sayMembersCount();
}
