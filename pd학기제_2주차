//15. 타입 비교 연산자
void main15() {
  int number1 = 1;

  print(number1 is int); //true
  print(number1 is String); //false
  print(number1 is! int); //false. !는 반대를 의미합니다.
  print(number1 is! String); //true
}

//16. 논리 연산자 - and, or
