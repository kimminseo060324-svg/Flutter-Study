}

//17. 제어문 - if, switch, for, while문
void main17() {
  int number = 2;
  
  if(number % 3 == 0) {
    print('3의 배수');
  } else if (number%3 == 1) {
    print('나머지 1');
  } else if {
    print('맞는 조건 없음')
  }
}

