}

//13. null 관련 연산자 - 다트 언어에서는 변수 타입이 null값을 가지는지 여부를 직접 지정
void main13() {
  //타입 뒤에 ?를 명시했기에 null값 가질 수 있음
  double? number1 = 1;

  double? number2;
  print(number2); //null 출력

  number2 ??= 3; //??를 사용하면 기존 값이 null일 때만 저장됨 (앞에서 null을 먼저 넣어줘야 사용가능!)
  number2 ??= 4; //null이 아니므로 3 유지
}

