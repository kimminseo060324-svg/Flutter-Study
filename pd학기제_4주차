// 2.2 객체지향 프로그래밍의 시작, 클래스
// 객체지향 프로그래밍의 기본은 class로 시작됨
// class 키워드를 입력 후 클래스명을 지정해 클래스를 선언합니다.
// $ : 문자열("" 또는 '') 안에 변수나 식의 값을 직접 삽입하고 싶을 때 사용
class Idol {
  // 1. 클래스에 종속되는 변수를 지정할 수 있습니다.
  String name = '블랙핑크';

  // 2. 클래스에 종속되는 함수를 지정할 수 있습니다.
  // 클래스에 종속되는 함수를 메서드라고 부릅니다.
void sayName() {

  // 3. 클래스 내부의 속성을 지칭하고 싶을 때는 this 키워드를 사용하면 됩니다.
  // 결과적으로 this.name은 Idol 클래스의 name 변수를 지칭합니다.
  print('저는 ${this.name}입니다.');
  // 4. 스코프 안에 같은 속성 이름이 하나만 존재한다면 this를 생략할 수 있습니다.
  print('저는 $name입니다.');
}
void main() {
  // 변수 타입을 Idol로 지정하고 Idol의 인스턴스를 생성할 수 있습니다.
  // 인스턴스를 생성할 때는 함수를 실행하는 것처럼
  // 인스턴스화하고 싶은 클래스에 괄호를 열고 닫아줍니다.
  Idol blackPink = Idol();

  // 메서드를 실행합니다.
  blackPink.sayName();
}
}

// 2.2.1 생성자
// 생성자는 클래스의 인스턴스(객체)를 생성하는 특별한 메서드
class Idol2 {
  // 1. 생성자에서 입력받는 변수들은 값이 한 번 정해지면 바꿀 수 없도록
  // 일반적으로 final 키워드를 사용합니다. (불변성 유지)
  final String name;

  // 2. 생성자 선언 (이니셜라이저 리스트 방식)
  // 클래스와 이름이 같아야 하며, 파라미터로 받은 값을
  // 콜론(:) 뒤에서 this.name 변수에 직접 대입해줍니다.
  Idol2(String name) : this.name = name;

  // 인스턴스의 이름을 출력하는 메서드
  void sayName() {
    print('저는 ${this.name}입니다.');
  }

  // 실행 예시 (보통 클래스 외부의 main 함수에서 실행함)
  void main2() {
    // Idol2 클래스의 인스턴스를 생성하며 '블랙핑크'라는 값을 전달
    Idol2 blackPink = Idol2('블랙핑크');
    blackPink.sayName();
  }
}

// 2.2.2 네임드 생성자
class Idol3 {
  final String name;
  final int membersCount

  //1. 생성자
Idol3(String name, int membersCount)
  // 1개 이상의 변수를 저장하고 싶을 때는 , 기호로 연결해주기
  : this.name = name,
  this.membersCount = membersCount;

  // 2. 네임드 생성자
  // {클래스명. 네임드 생성자명} 형식
  // 나머지 과정은 기본 생성자와 같습니다.
Idol3.fromMap(Map<String, dynamic>map)
  : this.name = map['name'],
    this.membersCount = map['membersCount'];

void sayName() {
  print('저는 ${this.name}입니다. ${this.name} 멤버는 ${this.membersCount} 명입니다.');
}
}
void main3() {
  // 기본 생성자 사용
  Idol3 blackPink = Idol3('블랙핑크',4);
  blackPink.sayName();

  // fromMap이라는 네임드 생성자 사용
  Idol3 bts = Idol3.fromMap({
    'name':'bts',
    'membersCount':7,
  });
  bts.sayName();
}

//2.2.3 프라이빗 변수
class Idol4 {
  // 1.'_'로 변수명을 시작하면
  // 프라이빗 변수를 선언할 수 있습니다.
  String _name;

  Idol(this._name);
}

void main4() {
  Idol blackPink = Idol('블랙핑크');

  // 같은 파일에서는 _name 변수에 접근할 수 있지만
  // 다른 파일에서는 _name 변수에 접근할 수 없습니다.
  print(blackPink._name);
}

//2.2.4 게터.세터
class Idol5 {
  String _name = '블랙핑크';

  // 1. get 키워드를 사용해서 게터임을 명시합니다.
  // 게터는 메서드와 다르게 매개 변수를 전혀 받지 않습니다.
  String get name {
    return this._name;
  }

  //2. 세터는 set이라는 키워드를 사용해서 선언합니다.
  // 세터는 매개변수로 딱 하나의 변수를 받을 수 있습니다.
set name(String name) {
    this._name = name;
}
}

void main5() {
  Idol blackPink = Idol();
  blackPink.name = '에이핑크'; // 1. 세터
  print(blackPink.name);
}

// 2.3 상속
class Idol6 {
  final String name;
  final int membersCount;

  Idol6(this.name, thismembersCount);

  void sayName() {
    print('저는 ${this.name}입니다.');
  }

  void sayMembersCount() {
    print('${this.name} 멤버는 ${this.membersCount}명입니다.');
  }

  // 1.extends 키워드를 사용해서 상속받습니다.
  // class 자식 클래스 extends 부모 클래스 순서입니다.
class BoyGroup extends Idol {
    BoyGroup (
      String name;
      int membersCount,
    ) : super( //super는 부모 클래스를 지칭함
  name, membersCount, );

    // 2. 상속받지 않은 기능
  void sayMale() {
    print('저는 남자 아이돌');
  }
  }

}

void main6() {
  BoyGroup bts = BoyGroup('BTS',7) // 생성자로 객체 생성

  bts.sayName(); //1. 부모한테 물려받은 메서드
  bts.sayMembersCount(); //2. 부모한테 물려받은 메서드
  bts.sayMale(); //3. 자식이 새로 추가한 메서드
}

// 2.4 오버라이드
class GirlGroup extends Idol7 {
  // 2.3 상속에서처럼 super 키워드를 사용해도 되고 다름처럼 생성자의 매개변수로
  // 직접 super 키워드를 사용해도 됩니다.
  GirlGroup(
      super.name, super.membersCount,
      );
  
  // 1. override 키워드를 사용해 오버라이드합니다.
@override
  void sayName() {
  print('저는 여자 아이돌 ${this.name}입니다.');
}
}
